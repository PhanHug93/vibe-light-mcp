# ============================================================================
# Environment Variables — TechStack Local MCP Server (Production)
# ============================================================================
# Copy this file to .env and customize:
#   cp .env.example .env
#
# Target: Ubuntu Server (Intel i5, 8GB RAM)
# ============================================================================

# --- MCP Server ---
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_EXEC_MODE=allowlist

# --- Ports (host mapping) ---
# Chỉ MCP Server được expose. ChromaDB là internal-only.
MCP_EXTERNAL_PORT=8000

# --- ChromaDB (internal, không cần thay đổi) ---
# MCP_CHROMA_HOST và MCP_CHROMA_PORT được hardcode trong docker-compose.yml
# vì ChromaDB chỉ giao tiếp nội bộ qua Docker network.
